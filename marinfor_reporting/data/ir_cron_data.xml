<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ir_cron_daily_debrief" model="ir.cron">
            <field name="name">Marinfor: Debrief Quotidien Automatique</field>
            <field name="model_id" ref="model_marinfor_daily_report"/>
            <field name="state">code</field>
            <field name="code">model.send_daily_debrief()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 07:00:00')"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
