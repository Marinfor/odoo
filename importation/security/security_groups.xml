<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_import_tracking" model="ir.module.category">
        <field name="name">importation Marinfor</field>
        <field name="description">Gestion de l importation Marinfor</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_import_user" model="res.groups">
        <field name="name">Utilisateur</field>
        <field name="category_id" ref="module_category_import_tracking"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_import_manager" model="res.groups">
        <field name="name">Responsable</field>
        <field name="category_id" ref="module_category_import_tracking"/>
        <field name="implied_ids" eval="[(4, ref('group_import_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>