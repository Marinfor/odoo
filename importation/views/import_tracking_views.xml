<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_tracking_tree" model="ir.ui.view">
        <field name="name">import.tracking.tree</field>
        <field name="model">import.tracking</field>
        <field name="arch" type="xml">
            <tree string="importation Marinfor">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="forwarder_id"/>
                <field name="invoice_number"/>
                <field name="date_d10"/>
                <field name="total_amount_global" widget="monetary" options="{'currency_field': 'currency_id'}" decoration-info="True"/>
                <field name="total_tva_global" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="total_cost_price" widget="monetary" options="{'currency_field': 'currency_id'}" decoration-bf="True" decoration-success="True"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge" decoration-info="state == 'shipped'" decoration-success="state == 'received'"/>
            </tree>
        </field>
    </record>

    <record id="view_import_tracking_form" model="ir.ui.view">
        <field name="name">import.tracking.form</field>
        <field name="model">import.tracking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirmer" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_done" string="Réceptionné" type="object" invisible="state != 'customs'" class="oe_highlight"/>
                    <button name="%(importation.action_report_fiche_importation)d" string="Imprimer Fiche Importation" type="action" invisible="state != 'confirmed'" class="btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,shipped,customs,received" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Référence Importation"/>
                        <h1><field name="name" placeholder="Fournisseur - Année - N°"/></h1>
                    </div>
                    <group>
                        <group string="Références Dossier" name="group_refs">
                            <field name="contract_number" placeholder="N° de Contrat"/>
                        </group>
                    </group>
                    <group string="Douane Algérienne" name="group_d10">
                        <group name="d10_left">
                            <field name="d10_number"/>
                            <field name="date_d10"/>
                            <field name="d10_nature"/>
                            <field name="receipt_number"/>
                        </group>
                        <group name="d10_right">
                            <field name="rps_frais" string="RPS"/>
                            <field name="amd_frais" string="AMD"/>
                            <field name="tel_frais" string="TEL"/>
                            <field name="du_frais" string="DU"/>
                            <field name="other_d10_details" invisible="other_d10_frais == 0"/>
                            <field name="other_d10_frais"/>
                        </group>
                    </group>

                    <group>
                        <group string="Fournisseur &amp; Initial" name="group_vendor">
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="invoice_number"/>
                            <field name="invoice_date"/>
                            <label for="initial_amount" string="Facture (Devise)"/>
                            <div class="o_row">
                                <field name="initial_amount" class="oe_inline"/>
                                <field name="initial_currency_id" options="{'no_create': True, 'no_open': True}" class="oe_inline" required="1"/>
                            </div>
                            <field name="exchange_rate" required="1"/>
                            <field name="amount_dzd_working" widget="monetary" options="{'currency_field': 'currency_id'}" decoration-bf="1"/>
                        </group>
                        
                        <group string="Transitaire (Transit)" name="group_transit">
                            <field name="forwarder_id" options="{'no_create': True}"/>
                            <field name="transit_invoice_number"/>
                            <field name="transit_amount_ht" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="transit_tva_rate" widget="radio" options="{'horizontal': true}"/>
                            <field name="transit_amount_tva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="transit_amount_ttc" widget="monetary" options="{'currency_field': 'currency_id'}" decoration-bf="1"/>
                        </group>
                    </group>

                    <group string="Récapitulatif Assiette Douane" name="group_finance_info">
                        <field name="amount_ttc" widget="monetary" options="{'currency_field': 'currency_id'}" string="Assiette Douane Totale" class="text-info font-weight-bold h3"/>
                        <field name="currency_id" invisible="1"/>
                    </group>

                    <div class="row mt-4">
                        <div class="col-6">
                            <group string="Récapitulatif D10 (Taxes Douane)" class="oe_subtotal_footer">
                                <field name="amount_dd" widget="monetary" options="{'currency_field': 'currency_id'}" string="Droits de Douane (DD)" decoration-bf="True"/>
                                <field name="amount_tva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="amount_prct" widget="monetary" options="{'currency_field': 'currency_id'}" string="PRCT"/>
                                <field name="amount_tcs" widget="monetary" options="{'currency_field': 'currency_id'}" string="TCS"/>
                                <field name="other_d10_details" string="Nature Autres Taxes" placeholder="ex: RPS" invisible="other_d10_frais == 0"/>
                                <field name="other_d10_frais" widget="monetary" options="{'currency_field': 'currency_id'}" string="Montant Autres Taxes"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="amount_total_d10" string="MONTANT QUITTANCE"/>
                                </div>
                                <field name="amount_total_d10" nolabel="1" widget="monetary" options="{'currency_field': 'currency_id'}" class="oe_subtotal_footer_separator text-primary font-weight-bold"/>
                            </group>
                        </div>
                        <div class="col-6">
                            <group string="Synthèse &amp; Coût de Revient" class="oe_subtotal_footer">
                                <field name="total_amount_global" widget="monetary" options="{'currency_field': 'currency_id'}" string="Montant Global TTC"/>
                                <field name="total_tva_global" widget="monetary" options="{'currency_field': 'currency_id'}" string="TVA"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="total_cost_price" string="COÛT DE REVIENT TOTAL"/>
                                </div>
                                <field name="total_cost_price" nolabel="1" class="oe_subtotal_footer_separator text-success font-weight-bold" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </div>
                    </div>
                    
                    <notebook>
                        <page string="Détails Produits (D10)" name="products">
                            <field name="product_line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="name" placeholder="Description du produit" required="1"/>
                                    <field name="product_id" options="{'no_create': True}" optional="hide"/>
                                    <field name="amount_base" string="Assiette" sum="Total Assiette" decoration-info="True" decoration-bf="True"/>
                                    <field name="rate_dd" string="Taux DD (%)" widget="float"/>
                                    <field name="amount_dd" string="Montant DD" sum="Total DD" decoration-success="True"/>
                                    <field name="amount_tcs" string="TCS (3%)" sum="Total TCS"/>
                                    <field name="amount_tva" string="TVA (19%)" sum="Total TVA"/>
                                    <field name="amount_prct" string="PRCT (2%)" sum="Total PRCT"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Autres Frais (Transport, etc.)" name="other_expenses">
                            <field name="expense_line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="name" placeholder="ex: Frais Transitaire, Magasinage..."/>
                                    <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="tva_rate"/>
                                    <field name="tva_amount" widget="monetary" readonly="1" options="{'currency_field': 'currency_id'}"/>
                                    <field name="total_amount" widget="monetary" readonly="1" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_expenses_ht" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="total_expenses_tva" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="total_expenses_ttc" string="Total Autres Frais"/>
                                </div>
                                <field name="total_expenses_ttc" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </page>
                    </notebook>
                    
                    <group string="Synthèse Financière et Coût de Revient" class="oe_subtotal_footer oe_right">
                        <field name="total_amount_global" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        <field name="total_tva_global" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                            <label for="total_cost_price" string="Coût de Revient Total"/>
                        </div>
                        <field name="total_cost_price" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    </group>
                    <div class="clearfix"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_import_tracking" model="ir.actions.act_window">
        <field name="name">importation Marinfor</field>
        <field name="res_model">import.tracking</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>
</odoo>