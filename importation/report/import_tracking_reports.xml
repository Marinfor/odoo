<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_fiche_importation" model="ir.actions.report">
        <field name="name">Fiche Importation</field>
        <field name="model">import.tracking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">importation.report_fiche_importation_template</field>
        <field name="report_file">importation.report_fiche_importation_template</field>
        <field name="print_report_name">'Fiche Importation - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_import_tracking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_fiche_importation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11px; color: #000; width: 100%;">
                        
                        <!-- Table-based Layout for Maximum Compatibility -->
                        <table style="width: 100%; border-bottom: 2px solid black; margin-bottom: 20px;">
                            <tr>
                                <td style="width: 50%; vertical-align: bottom; padding-bottom: 5px;">
                                    <span style="font-size: 10px; font-weight: bold; text-transform: uppercase;">REF : </span>
                                    <span style="font-size: 14px; font-weight: bold;"><t t-esc="doc.name"/></span>
                                </td>
                                <td style="width: 50%; text-align: right; vertical-align: bottom; padding-bottom: 5px;">
                                    <t t-if="doc.contract_number">
                                        <span style="font-size: 10px; font-weight: bold; text-transform: uppercase;">CONTRAT : </span>
                                        <span style="font-size: 14px; font-weight: bold;"><t t-esc="doc.contract_number"/></span>
                                    </t>
                                </td>
                            </tr>
                        </table>

                        <div style="text-align: center; font-size: 24px; font-weight: bold; text-transform: uppercase; border: 2px solid black; padding: 10px; margin-bottom: 20px;">
                            FICHE D'IMPORTATION
                        </div>

                        <!-- SECTION FOURNISSEUR -->
                        <div style="border: 1.5px solid black; margin-bottom: 20px;">
                            <div style="background-color: #f2f2f2; border-bottom: 1.5px solid black; padding: 5px 10px; font-weight: bold; text-transform: uppercase;">
                                Informations Fournisseur
                            </div>
                            <table style="width: 100%; padding: 10px; border-collapse: collapse;">
                                <tr>
                                    <td style="width: 60%; vertical-align: top;">
                                        <span style="font-weight: bold; font-size: 10px;">FOURNISSEUR :</span><br/>
                                        <span style="font-size: 13px; font-weight: bold;"><t t-esc="doc.partner_id.name"/></span><br/><br/>
                                        <span style="font-weight: bold; font-size: 10px;">ADRESSE :</span><br/>
                                        <t t-esc="doc.partner_id.street"/>, <t t-esc="doc.partner_id.city"/> <t t-esc="doc.partner_id.country_id.name"/>
                                    </td>
                                    <td style="width: 40%; vertical-align: top; border-left: 1px dashed black; padding-left: 10px;">
                                        <table style="width: 100%;">
                                            <tr><td><strong>FACTURE N° :</strong></td><td style="text-align: right;"><t t-esc="doc.invoice_number"/></td></tr>
                                            <tr><td><strong>DATE :</strong></td><td style="text-align: right;"><t t-esc="doc.invoice_date"/></td></tr>
                                            <tr><td colspan="2" style="border-top: 1px solid #ccc; padding-top: 5px; margin-top: 5px;"></td></tr>
                                            <tr><td><strong>MONTANT DEVISE :</strong></td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.initial_amount" t-options='{"widget": "monetary", "display_currency": doc.initial_currency_id}'/></td></tr>
                                            <tr><td><strong>TAUX CHANGE :</strong></td><td style="text-align: right;"><t t-esc="doc.exchange_rate"/></td></tr>
                                            <tr style="font-size: 12px; border-top: 1px solid black;"><td style="padding-top: 5px;"><strong>TOTAL (DZD) :</strong></td><td style="text-align: right; font-weight: bold; padding-top: 5px;"><t t-esc="doc.amount_dzd_working" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- SECTION DOUANE ALGERIENNE -->
                        <div style="border: 1.5px solid black; margin-bottom: 20px;">
                            <div style="background-color: #f2f2f2; border-bottom: 1.5px solid black; padding: 5px 10px; font-weight: bold; text-transform: uppercase;">
                                Douane Algérienne
                            </div>
                            <div style="padding: 10px;">
                                <table style="width: 100%; margin-bottom: 15px;">
                                    <tr>
                                        <td style="width: 33%;"><strong>N° D10 :</strong> <t t-esc="doc.d10_number"/></td>
                                        <td style="width: 33%; text-align: center;"><strong>DATE D10 :</strong> <t t-esc="doc.date_d10"/></td>
                                        <td style="width: 33%; text-align: right;"><strong>N° QUITTANCE :</strong> <span style="font-weight: bold;"><t t-esc="doc.receipt_number"/></span></td>
                                    </tr>
                                </table>

                                <table style="width: 100%;">
                                    <tr>
                                        <!-- Taxes Produits -->
                                        <td style="width: 48%; vertical-align: top; border-right: 1px solid #000; padding-right: 10px;">
                                            <div style="font-size: 9px; font-weight: bold; margin-bottom: 5px;">TAXES SUR PRODUITS</div>
                                            <table style="width: 100%;">
                                                <tr style="border-bottom: 1px solid #eee;"><td>DROIT DE DOUANE (DD)</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.amount_dd" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>TVA IMPORTATION</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>PRCT / IBS</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.amount_prct" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>TCS</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.amount_tcs" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            </table>
                                        </td>
                                        <!-- Frais Quittance -->
                                        <td style="width: 48%; vertical-align: top; padding-left: 10px;">
                                            <div style="font-size: 9px; font-weight: bold; margin-bottom: 5px;">FRAIS FIXES &amp; QUITTANCE</div>
                                            <table style="width: 100%;">
                                                <tr style="border-bottom: 1px solid #eee;"><td>RPS</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.rps_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>AMD</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.amd_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>TEL</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.tel_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>DU</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.du_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            </table>
                                        </td>
                                    </tr>
                                </table>
                                
                                <div style="margin-top: 15px; text-align: right; border-top: 1.5px solid black; padding-top: 5px;">
                                    <span style="font-size: 12px; font-weight: bold;">MONTANT QUITTANCE TOTAL : </span>
                                    <span style="font-size: 16px; font-weight: bold; margin-left: 10px;"><t t-esc="doc.amount_total_d10" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></span>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION TRANSIT -->
                        <div style="border: 1.5px solid black; margin-bottom: 20px;">
                            <div style="background-color: #f2f2f2; border-bottom: 1.5px solid black; padding: 5px 10px; font-weight: bold; text-transform: uppercase;">
                                Transit
                            </div>
                            <table style="width: 100%; padding: 10px;">
                                <tr>
                                    <td style="width: 50%; vertical-align: top;">
                                        <strong>TRANSITAIRE :</strong> <t t-esc="doc.forwarder_id.name"/><br/>
                                        <strong>FACTURE N° :</strong> <t t-esc="doc.transit_invoice_number"/>
                                    </td>
                                    <td style="width: 50%; vertical-align: top;">
                                        <table style="width: 100%;">
                                            <tr><td>MONTANT H.T</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.transit_amount_ht" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td>TVA (<t t-esc="doc.transit_tva_rate"/>%)</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.transit_amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr style="background-color: #f9f9f9; border-top: 1px solid black;"><td>TOTAL T.T.C</td><td style="text-align: right; font-weight: bold;"><t t-esc="doc.transit_amount_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- SECTION AUTRES FRAIS -->
                        <div style="border: 1.5px solid black; margin-bottom: 20px;">
                            <div style="background-color: #f2f2f2; border-bottom: 1.5px solid black; padding: 5px 10px; font-weight: bold; text-transform: uppercase;">
                                Autres Frais &amp; Débours
                            </div>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead style="background-color: #f9f9f9;">
                                    <tr>
                                        <th style="text-align: left; padding: 5px 10px; border-bottom: 1px solid black;">Description</th>
                                        <th style="text-align: right; padding: 5px; border-bottom: 1px solid black;">HT</th>
                                        <th style="text-align: right; padding: 5px; border-bottom: 1px solid black;">TVA</th>
                                        <th style="text-align: right; padding: 5px 10px; border-bottom: 1px solid black;">TOTAL TTC</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.expense_line_ids" t-as="line">
                                        <tr style="border-bottom: 1px solid #eee;">
                                            <td style="padding: 5px 10px;"><t t-esc="line.name"/></td>
                                            <td style="text-align: right; padding: 5px;"><t t-esc="line.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                            <td style="text-align: right; padding: 5px;"><t t-esc="line.tva_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                            <td style="text-align: right; padding: 5px 10px; font-weight: bold;"><t t-esc="line.total_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="background-color: #f2f2f2; font-weight: bold;">
                                        <td colspan="3" style="text-align: right; padding: 8px;">TOTAL AUTRES FRAIS</td>
                                        <td style="text-align: right; padding: 8px 10px;"><t t-esc="doc.total_expenses_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <!-- RECAPITULATIF FINAL -->
                        <table style="width: 100%; border: 3px solid black; margin-top: 10px;">
                            <tr>
                                <td style="padding: 15px;">
                                    <span style="font-size: 14px; font-weight: bold; text-transform: uppercase;">Coût de Revient Total de l'Importation</span>
                                </td>
                                <td style="text-align: right; padding: 15px; background-color: #f2f2f2;">
                                    <span style="font-size: 20px; font-weight: bold;"><t t-esc="doc.total_cost_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></span>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
