<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_fiche_importation" model="ir.actions.report">
        <field name="name">Fiche Importation</field>
        <field name="model">import.tracking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">importation.report_fiche_importation_template</field>
        <field name="report_file">importation.report_fiche_importation_template</field>
        <field name="print_report_name">'Fiche Importation - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_import_tracking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_fiche_importation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', 'Arial', sans-serif; color: #333; line-height: 1.4;">
                        
                        <!-- Modern Styling -->
                        <style>
                            .report-header {
                                display: flex;
                                justify-content: space-between;
                                align-items: flex-start;
                                margin-bottom: 30px;
                                border-bottom: 2px solid #2C3E50;
                                padding-bottom: 10px;
                            }
                            .report-title {
                                font-size: 28px;
                                font-weight: 800;
                                color: #2C3E50;
                                text-align: center;
                                margin-top: 20px;
                                margin-bottom: 40px;
                                text-transform: uppercase;
                                letter-spacing: 2px;
                            }
                            .card {
                                border: 1px solid #EAECEF;
                                border-radius: 4px;
                                margin-bottom: 25px;
                                overflow: hidden;
                            }
                            .card-header {
                                background-color: #F8F9FA;
                                border-bottom: 1px solid #EAECEF;
                                padding: 8px 15px;
                                font-weight: bold;
                                color: #2C3E50;
                                text-transform: uppercase;
                                font-size: 13px;
                            }
                            .card-body {
                                padding: 15px;
                            }
                            .info-grid {
                                width: 100%;
                                display: flex;
                                flex-wrap: wrap;
                            }
                            .info-item {
                                flex: 0 0 50%;
                                margin-bottom: 8px;
                            }
                            .info-label {
                                color: #7F8C8D;
                                font-size: 10px;
                                text-transform: uppercase;
                                font-weight: 600;
                                display: block;
                            }
                            .info-value {
                                color: #2C3E50;
                                font-size: 12px;
                                font-weight: 500;
                            }
                            .data-table {
                                width: 100%;
                                margin-top: 10px;
                                border-collapse: collapse;
                            }
                            .data-table th {
                                text-align: left;
                                font-size: 11px;
                                color: #7F8C8D;
                                border-bottom: 1px solid #DEE2E6;
                                padding: 8px 5px;
                            }
                            .data-table td {
                                padding: 10px 5px;
                                border-bottom: 1px solid #F1F3F5;
                                font-size: 12px;
                            }
                            .amount-column {
                                text-align: right;
                                font-family: 'Courier', monospace;
                                font-weight: 600;
                            }
                            .total-box {
                                background-color: #2C3E50;
                                color: white;
                                padding: 15px;
                                border-radius: 4px;
                                margin-top: 20px;
                                display: flex;
                                justify-content: space-between;
                                align-items: center;
                            }
                            .summary-row {
                                border-top: 2px solid #2C3E50;
                                background-color: #F8F9FA;
                                font-weight: bold;
                            }
                            .badge-light {
                                background-color: #E9ECEF;
                                padding: 2px 6px;
                                border-radius: 3px;
                                font-size: 10px;
                                color: #495057;
                            }
                        </style>

                        <!-- Header Info -->
                        <div class="report-header">
                            <div>
                                <div class="info-label">Référence Dossier</div>
                                <div class="info-value" style="font-size: 16px; font-weight: bold;"><t t-esc="doc.name"/></div>
                                <t t-if="doc.folder_number">
                                    <div class="badge-light mt-1">Dossier: <t t-esc="doc.folder_number"/></div>
                                </t>
                            </div>
                            <div class="text-right">
                                <div class="info-label">Date d'importation</div>
                                <div class="info-value"><t t-esc="doc.create_date" t-options='{"widget": "date"}'/></div>
                                <t t-if="doc.contract_number">
                                    <div class="badge-light mt-1">Contrat: <t t-esc="doc.contract_number"/></div>
                                </t>
                            </div>
                        </div>

                        <div class="report-title">Fiche de Synthèse Importation</div>

                        <div class="row">
                            <!-- Bloc Fournisseur & Facture -->
                            <div class="col-6">
                                <div class="card h-100">
                                    <div class="card-header">Fournisseur &amp; Facture</div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <div class="info-label">Fournisseur</div>
                                            <div class="info-value"><t t-esc="doc.partner_id.name"/></div>
                                        </div>
                                        <div class="row">
                                            <div class="col-6">
                                                <div class="info-label">N° Facture</div>
                                                <div class="info-value"><t t-esc="doc.invoice_number"/></div>
                                            </div>
                                            <div class="col-6">
                                                <div class="info-label">Date Facture</div>
                                                <div class="info-value"><t t-esc="doc.invoice_date"/></div>
                                            </div>
                                        </div>
                                        <hr/>
                                        <div class="row">
                                            <div class="col-6">
                                                <div class="info-label">Montant Devise</div>
                                                <div class="info-value" style="font-size: 14px; font-weight: bold; color: #E67E22;">
                                                    <t t-esc="doc.initial_amount" t-options='{"widget": "monetary", "display_currency": doc.initial_currency_id}'/>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="info-label">Taux de Change</div>
                                                <div class="info-value"><t t-esc="doc.exchange_rate"/></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Bloc Transit & Logistique -->
                            <div class="col-6">
                                <div class="card h-100">
                                    <div class="card-header">Transit &amp; Logistique</div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <div class="info-label">Transitaire</div>
                                            <div class="info-value"><t t-esc="doc.forwarder_id.name or 'Non assigné'"/></div>
                                        </div>
                                        <div class="row">
                                            <div class="col-12">
                                                <div class="info-label">Facture Transit</div>
                                                <div class="info-value"><t t-esc="doc.transit_invoice_number"/></div>
                                            </div>
                                        </div>
                                        <hr/>
                                        <div class="row">
                                            <div class="col-6">
                                                <div class="info-label">Montant Transit HT</div>
                                                <div class="info-value"><t t-esc="doc.transit_amount_ht" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></div>
                                            </div>
                                            <div class="col-6">
                                                <div class="info-label">Montant Transit TTC</div>
                                                <div class="info-value" style="font-weight: bold;"><t t-esc="doc.transit_amount_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Bloc Douane (D10) Detail -->
                        <div class="card">
                            <div class="card-header">Déclaration Douanière (D10)</div>
                            <div class="card-body">
                                <div class="row mb-3">
                                    <div class="col-3">
                                        <div class="info-label">Numéro D10</div>
                                        <div class="info-value"><t t-esc="doc.d10_number"/></div>
                                    </div>
                                    <div class="col-3">
                                        <div class="info-label">Date D10</div>
                                        <div class="info-value"><t t-esc="doc.date_d10"/></div>
                                    </div>
                                    <div class="col-3">
                                        <div class="info-label">Nature D10</div>
                                        <div class="info-value"><t t-esc="doc.d10_nature"/></div>
                                    </div>
                                    <div class="col-3 text-right">
                                        <div class="info-label">N° Quittance</div>
                                        <div class="info-value" style="color: #2980B9;"><t t-esc="doc.receipt_number"/></div>
                                    </div>
                                </div>
                                
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Description des Taxes &amp; Droits</th>
                                            <th class="text-right">Montant Unitaire (DZD)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Droits de Douane (DD)</td>
                                            <td class="amount-column"><t t-esc="doc.amount_dd" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td>TVA Importation</td>
                                            <td class="amount-column"><t t-esc="doc.amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td>PRCT / IBS</td>
                                            <td class="amount-column"><t t-esc="doc.amount_prct" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <tr>
                                            <td>TCS</td>
                                            <td class="amount-column"><t t-esc="doc.amount_tcs" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                        <t t-if="doc.rps_frais > 0">
                                            <tr><td>Redevance Prestations de Services (RPS)</td><td class="amount-column"><t t-esc="doc.rps_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </t>
                                        <t t-if="doc.amd_frais > 0">
                                            <tr><td>AMD / Magasinage</td><td class="amount-column"><t t-esc="doc.amd_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </t>
                                        <t t-if="doc.tel_frais > 0">
                                            <tr><td>Frais Télécom / Divers</td><td class="amount-column"><t t-esc="doc.tel_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </t>
                                        <tr class="summary-row">
                                            <td style="font-weight: bold; font-size: 14px;">MONTANT TOTAL QUITTANCE QUITTANCE</td>
                                            <td class="amount-column text-primary" style="font-size: 16px;"><t t-esc="doc.amount_total_d10" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Frais Annexes Section -->
                        <div class="card">
                            <div class="card-header">Détails des Frais Annexes &amp; Autres</div>
                            <div class="card-body p-0">
                                <table class="data-table mb-0" style="margin-top: 0;">
                                    <thead style="background-color: #FBFCFD;">
                                        <tr>
                                            <th style="padding-left: 15px;">Désignation des Frais</th>
                                            <th class="text-right">HT</th>
                                            <th class="text-right">TVA</th>
                                            <th class="text-right" style="padding-right: 15px;">Total TTC</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.expense_line_ids" t-as="line">
                                            <tr>
                                                <td style="padding-left: 15px;"><t t-esc="line.name"/></td>
                                                <td class="amount-column"><t t-esc="line.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                                <td class="amount-column"><t t-esc="line.tva_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                                <td class="amount-column" style="padding-right: 15px;"><t t-esc="line.total_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                            </tr>
                                        </t>
                                        <t t-if="not doc.expense_line_ids">
                                            <tr><td colspan="4" class="text-center text-muted italic">Aucun frais annexe enregistré</td></tr>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr style="background-color: #F8F9FA;">
                                            <td colspan="3" style="font-weight: bold; text-align: right; padding: 12px;">Total Frais Annexes</td>
                                            <td class="amount-column" style="padding: 12px 15px; font-size: 14px;"><t t-esc="doc.total_expenses_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>

                        <!-- Final Summary Box -->
                        <div class="total-box">
                            <div>
                                <div style="font-size: 12px; opacity: 0.8; text-transform: uppercase;">Récapitulatif Global</div>
                                <div style="font-size: 18px; font-weight: 300;">Analyse des coûts de revient</div>
                            </div>
                            <div style="text-align: right;">
                                <div style="font-size: 12px; opacity: 0.8;">COÛT DE REVIENT TOTAL</div>
                                <div style="font-size: 28px; font-weight: bold;"><t t-esc="doc.total_cost_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
