<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_fiche_importation" model="ir.actions.report">
        <field name="name">Fiche Importation</field>
        <field name="model">import.tracking</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">importation.report_fiche_importation_template</field>
        <field name="report_file">importation.report_fiche_importation_template</field>
        <field name="print_report_name">'Fiche Importation - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_import_tracking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_fiche_importation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: Arial, sans-serif; color: #000; line-height: 1.4; padding: 10px; font-size: 11px;">
                        
                        <style>
                            .doc-title {
                                font-size: 20px;
                                font-weight: bold;
                                text-align: center;
                                margin: 30px 0;
                                text-transform: uppercase;
                                border-top: 1px solid #000;
                                border-bottom: 1px solid #000;
                                padding: 10px 0;
                            }
                            .section-title {
                                font-weight: bold;
                                text-transform: uppercase;
                                border-bottom: 1px solid #000;
                                margin-bottom: 10px;
                                padding-bottom: 3px;
                                margin-top: 20px;
                            }
                            .data-table {
                                width: 100%;
                                border-collapse: collapse;
                            }
                            .data-table td {
                                padding: 5px 0;
                                border-bottom: 1px solid #eee;
                            }
                            .lbl { font-weight: bold; text-transform: uppercase; font-size: 10px; width: 140px; }
                            .val { border-bottom: 1px solid #ccc; min-height: 15px; }
                            .amount { text-align: right; font-weight: bold; }
                            .total-box {
                                margin-top: 15px;
                                text-align: right;
                                font-weight: bold;
                                font-size: 14px;
                                border-top: 1px solid #000;
                                padding-top: 5px;
                            }
                        </style>

                        <!-- Header Clean -->
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #000; padding-bottom: 5px; margin-bottom: 10px;">
                            <div>
                                <span class="lbl">REF :</span>
                                <span style="font-size: 13px; font-weight: bold; margin-left: 10px;"><t t-esc="doc.name"/></span>
                            </div>
                            <div style="text-align: right;">
                                <t t-if="doc.contract_number">
                                    <span class="lbl">CONTRAT :</span>
                                    <span style="font-size: 13px; font-weight: bold; margin-left: 10px;"><t t-esc="doc.contract_number"/></span>
                                </t>
                            </div>
                        </div>

                        <div class="doc-title">FIHCE D'IMPORTATION</div>

                        <!-- SECTION FOURNISSEUR -->
                        <div class="section-title">Informations Fournisseur</div>
                        <div style="padding-left: 10px;">
                            <div style="display: flex; margin-bottom: 5px;">
                                <div class="lbl">FOURNISSEUR :</div>
                                <div class="val" style="font-weight: bold; flex-grow: 1;"><t t-esc="doc.partner_id.name"/></div>
                            </div>
                            <div style="display: flex; margin-bottom: 15px;">
                                <div class="lbl">ADRESSE :</div>
                                <div class="val" style="flex-grow: 1;">
                                    <t t-esc="doc.partner_id.street"/>, <t t-esc="doc.partner_id.city"/> <t t-esc="doc.partner_id.country_id.name"/>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div style="display: flex; margin-bottom: 5px;">
                                        <div class="lbl">FACTURE N° :</div>
                                        <div class="val" style="flex-grow: 1;"><t t-esc="doc.invoice_number"/></div>
                                    </div>
                                    <div style="display: flex;">
                                        <div class="lbl">DATE :</div>
                                        <div class="val" style="flex-grow: 1;"><t t-esc="doc.invoice_date"/></div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div style="display: flex; margin-bottom: 5px;">
                                        <div class="lbl">MONTANT DEVISE :</div>
                                        <div class="val" style="text-align: right; flex-grow: 1; font-weight: bold;">
                                            <t t-esc="doc.initial_amount" t-options='{"widget": "monetary", "display_currency": doc.initial_currency_id}'/>
                                        </div>
                                    </div>
                                    <div style="display: flex;">
                                        <div class="lbl">TOTAL (DZD) :</div>
                                        <div class="val" style="text-align: right; flex-grow: 1; font-weight: bold;"><t t-esc="doc.amount_dzd_working" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION DOUANE ALGERIENNE -->
                        <div class="section-title">Douane Algérienne</div>
                        <div style="padding-left: 10px;">
                            <div class="row mb-3">
                                <div class="col-4">
                                    <span class="lbl">D10 N° :</span> <span class="val" style="display: inline-block; width: 100px;"><t t-esc="doc.d10_number"/></span>
                                </div>
                                <div class="col-4">
                                    <span class="lbl">DATE :</span> <span class="val" style="display: inline-block; width: 100px;"><t t-esc="doc.date_d10"/></span>
                                </div>
                                <div class="col-4">
                                    <span class="lbl">QUITTANCE N° :</span> <span class="val" style="display: inline-block; width: 100px; font-weight: bold;"><t t-esc="doc.receipt_number"/></span>
                                </div>
                            </div>

                            <div class="row">
                                <!-- Colonne 1: Taxes Produits -->
                                <div class="col-6 pr-4" style="border-right: 1px solid #eee;">
                                    <div style="font-size: 9px; font-weight: bold; margin-bottom: 5px;">TAXES SUR PRODUITS</div>
                                    <table class="data-table">
                                        <tr><td>DROIT DE DOUANE (DD)</td><td class="amount"><t t-esc="doc.amount_dd" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        <tr><td>TVA IMPORTATION</td><td class="amount"><t t-esc="doc.amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        <tr><td>PRCT / IBS</td><td class="amount"><t t-esc="doc.amount_prct" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        <tr><td>TCS</td><td class="amount"><t t-esc="doc.amount_tcs" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                    </table>
                                </div>
                                <!-- Colonne 2: Frais Quittance -->
                                <div class="col-6 pl-4">
                                    <div style="font-size: 9px; font-weight: bold; margin-bottom: 5px;">FRAIS FIXES &amp; QUITTANCE</div>
                                    <table class="data-table">
                                        <tr><td>RPS</td><td class="amount"><t t-esc="doc.rps_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        <tr><td>AMD</td><td class="amount"><t t-esc="doc.amd_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        <tr><td>TEL</td><td class="amount"><t t-esc="doc.tel_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        <tr><td>DU</td><td class="amount"><t t-esc="doc.du_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                    </table>
                                </div>
                            </div>
                            
                            <div class="total-box">
                                <span>MONTANT QUITTANCE TOTAL :</span>
                                <span style="font-size: 16px; margin-left: 20px;"><t t-esc="doc.amount_total_d10" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></span>
                            </div>
                        </div>

                        <!-- SECTION TRANSIT -->
                        <div class="section-title">Transit</div>
                        <div style="padding-left: 10px;">
                            <div class="row">
                                <div class="col-7">
                                    <div style="display: flex; margin-bottom: 5px;">
                                        <div class="lbl">TRANSITAIRE :</div>
                                        <div class="val" style="flex-grow: 1;"><t t-esc="doc.forwarder_id.name"/></div>
                                    </div>
                                    <div style="display: flex;">
                                        <div class="lbl">FACTURE N° :</div>
                                        <div class="val" style="flex-grow: 1;"><t t-esc="doc.transit_invoice_number"/></div>
                                    </div>
                                </div>
                                <div class="col-5">
                                    <table class="data-table">
                                        <tr><td>MONTANT H.T</td><td class="amount"><t t-esc="doc.transit_amount_ht" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        <tr><td>TVA (<t t-esc="doc.transit_tva_rate"/>%)</td><td class="amount"><t t-esc="doc.transit_amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        <tr style="font-weight: bold;"><td>TOTAL T.T.C</td><td class="amount"><t t-esc="doc.transit_amount_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION COÛT TOTAL -->
                        <div style="margin-top: 40px; border: 2px solid #000; padding: 15px; display: flex; justify-content: space-between; align-items: center;">
                            <div style="font-weight: bold; font-size: 14px; text-transform: uppercase;">Coût de Revient Total de l'Importation</div>
                            <div style="font-size: 20px; font-weight: bold;"><t t-esc="doc.total_cost_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
