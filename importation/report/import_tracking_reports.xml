<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_fiche_importation" model="ir.actions.report">
        <field name="name">Fiche Importation</field>
        <field name="model">import.tracking</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">importation.report_fiche_importation_template</field>
        <field name="report_file">importation.report_fiche_importation_template</field>
        <field name="print_report_name">'Fiche Importation - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_import_tracking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_fiche_importation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: 'Helvetica', 'Arial', sans-serif; color: #000; line-height: 1.4; padding: 20px;">
                        
                        <style>
                            .report-header {
                                display: flex;
                                justify-content: space-between;
                                align-items: flex-end;
                                margin-bottom: 25px;
                                border-bottom: 1px solid #000;
                                padding-bottom: 5px;
                            }
                            .report-title {
                                font-size: 22px;
                                font-weight: bold;
                                text-align: center;
                                margin: 30px 0;
                                text-transform: uppercase;
                                letter-spacing: 2px;
                                border-top: 1px solid #000;
                                border-bottom: 1px solid #000;
                                padding: 8px 0;
                            }
                            .section-box {
                                border: 1px solid #000;
                                margin-bottom: 15px;
                            }
                            .section-name {
                                border-bottom: 1px solid #000;
                                padding: 4px 10px;
                                font-weight: bold;
                                text-transform: uppercase;
                                font-size: 11px;
                            }
                            .section-content {
                                padding: 12px;
                            }
                            .field-row {
                                margin-bottom: 4px;
                                display: flex;
                                align-items: baseline;
                            }
                            .field-label {
                                font-weight: bold;
                                font-size: 10px;
                                text-transform: uppercase;
                                width: 130px;
                                flex-shrink: 0;
                            }
                            .field-value {
                                font-size: 11px;
                                border-bottom: 0.5px solid #eee;
                                flex-grow: 1;
                                min-height: 14px;
                            }
                            .data-table {
                                width: 100%;
                                border-collapse: collapse;
                            }
                            .data-table th {
                                border-bottom: 1px solid #000;
                                padding: 4px;
                                text-align: left;
                                font-size: 10px;
                                text-transform: uppercase;
                            }
                            .data-table td {
                                border-bottom: 0.5px solid #eee;
                                padding: 6px 4px;
                                font-size: 11px;
                            }
                            .amount-cell {
                                text-align: right;
                                font-weight: bold;
                            }
                            .total-highlight {
                                border-top: 1px solid #000;
                                font-weight: bold;
                                padding-top: 5px;
                                margin-top: 8px;
                                font-size: 13px;
                            }
                            .grand-summary {
                                margin-top: 25px;
                                border: 2px solid #000;
                                padding: 12px;
                            }
                        </style>

                        <!-- Header Classique -->
                        <div class="report-header">
                            <div>
                                <span style="font-weight: bold; font-size: 9px; text-transform: uppercase;">REF :</span>
                                <span style="font-weight: bold; font-size: 13px; margin-left: 10px;"><t t-esc="doc.name"/></span>
                            </div>
                            <div class="text-right">
                                <t t-if="doc.contract_number">
                                    <span style="font-weight: bold; font-size: 9px; text-transform: uppercase;">CONTRAT :</span>
                                    <span style="font-weight: bold; font-size: 13px; margin-left: 10px;"><t t-esc="doc.contract_number"/></span>
                                </t>
                            </div>
                        </div>

                        <div class="report-title">FICHE D'IMPORTATION</div>

                        <!-- FOURNISSEUR -->
                        <div class="section-box">
                            <div class="section-name">Informations Fournisseur</div>
                            <div class="section-content">
                                <div class="field-row">
                                    <span class="field-label">FOURNISSEUR :</span>
                                    <span class="field-value" style="font-weight: bold;"><t t-esc="doc.partner_id.name"/></span>
                                </div>
                                <div class="field-row">
                                    <span class="field-label">ADRESSE :</span>
                                    <span class="field-value">
                                        <t t-esc="doc.partner_id.street"/>, <t t-esc="doc.partner_id.city"/> <t t-esc="doc.partner_id.country_id.name"/>
                                    </span>
                                </div>
                                <div class="row" style="margin-top: 10px;">
                                    <div class="col-6">
                                        <div class="field-row">
                                            <span class="field-label">FACTURE N° :</span>
                                            <span class="field-value"><t t-esc="doc.invoice_number"/></span>
                                        </div>
                                        <div class="field-row">
                                            <span class="field-label">DATE :</span>
                                            <span class="field-value"><t t-esc="doc.invoice_date"/></span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="field-row">
                                            <span class="field-label">MONTANT DEVISE :</span>
                                            <span class="field-value" style="font-weight: bold; text-align: right;">
                                                <t t-esc="doc.initial_amount" t-options='{"widget": "monetary", "display_currency": doc.initial_currency_id}'/>
                                            </span>
                                        </div>
                                        <div class="field-row">
                                            <span class="field-label">TAUX CHANGE :</span>
                                            <span class="field-value" style="text-align: right;"><t t-esc="doc.exchange_rate"/></span>
                                        </div>
                                        <div class="field-row">
                                            <span class="field-label">TOTAL (DZD) :</span>
                                            <span class="field-value" style="font-weight: bold; text-align: right;"><t t-esc="doc.amount_dzd_working" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- DOUANE -->
                        <div class="section-box">
                            <div class="section-name">Douane Algérienne</div>
                            <div class="section-content">
                                <div class="row mb-3">
                                    <div class="col-4">
                                        <span class="field-label" style="width: auto;">N° DECLARATION (D10) :</span>
                                        <span class="field-value"><t t-esc="doc.d10_number"/></span>
                                    </div>
                                    <div class="col-4">
                                        <span class="field-label" style="width: auto;">DATE :</span>
                                        <span class="field-value"><t t-esc="doc.date_d10"/></span>
                                    </div>
                                    <div class="col-4">
                                        <span class="field-label" style="width: auto;">QUITTANCE N° :</span>
                                        <span class="field-value" style="font-weight: bold;"><t t-esc="doc.receipt_number"/></span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-6 pr-3" style="border-right: 1px solid #eee;">
                                        <table class="data-table">
                                            <tr><td>DROIT DE DOUANE (DD)</td><td class="amount-cell"><t t-esc="doc.amount_dd" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td>TVA IMPORTATION</td><td class="amount-cell"><t t-esc="doc.amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td>PRCT / IBS</td><td class="amount-cell"><t t-esc="doc.amount_prct" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td>TCS</td><td class="amount-cell"><t t-esc="doc.amount_tcs" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </table>
                                    </div>
                                    <div class="col-6 pl-3">
                                        <table class="data-table">
                                            <tr><td>RPS</td><td class="amount-cell"><t t-esc="doc.rps_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td>AMD</td><td class="amount-cell"><t t-esc="doc.amd_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td>TEL</td><td class="amount-cell"><t t-esc="doc.tel_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td>DU</td><td class="amount-cell"><t t-esc="doc.du_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </table>
                                    </div>
                                </div>
                                
                                <div class="total-highlight text-right">
                                    <span style="font-size: 11px;">MONTANT QUITTANCE TOTAL :</span>
                                    <span style="font-size: 15px; margin-left: 15px;"><t t-esc="doc.amount_total_d10" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></span>
                                </div>
                            </div>
                        </div>

                        <!-- TRANSIT -->
                        <div class="section-box">
                            <div class="section-name">Transit</div>
                            <div class="section-content">
                                <div class="row">
                                    <div class="col-7">
                                        <div class="field-row">
                                            <span class="field-label">TRANSITAIRE :</span>
                                            <span class="field-value"><t t-esc="doc.forwarder_id.name"/></span>
                                        </div>
                                        <div class="field-row">
                                            <span class="field-label">FACTURE N° :</span>
                                            <span class="field-value"><t t-esc="doc.transit_invoice_number"/></span>
                                        </div>
                                    </div>
                                    <div class="col-5">
                                        <table class="data-table" style="margin-top: 0;">
                                            <tr><td>MONTANT H.T</td><td class="amount-cell"><t t-esc="doc.transit_amount_ht" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td>TVA (<t t-esc="doc.transit_tva_rate"/>%)</td><td class="amount-cell"><t t-esc="doc.transit_amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr><td style="font-weight: bold;">TOTAL T.T.C</td><td class="amount-cell"><t t-esc="doc.transit_amount_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- AUTRES FRAIS -->
                        <div class="section-box">
                            <div class="section-name">Autres Frais &amp; Débours</div>
                            <div class="section-content p-0">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th style="padding-left: 10px;">Description</th>
                                            <th class="text-right">HT</th>
                                            <th class="text-right">TVA</th>
                                            <th class="text-right" style="padding-right: 10px;">TOTAL</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.expense_line_ids" t-as="line">
                                            <tr>
                                                <td style="padding-left: 10px;"><t t-esc="line.name"/></td>
                                                <td class="amount-cell"><t t-esc="line.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                                <td class="amount-cell"><t t-esc="line.tva_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                                <td class="amount-cell" style="padding-right: 10px;"><t t-esc="line.total_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr style="font-weight: bold;">
                                            <td colspan="3" style="text-align: right; padding: 8px;">TOTAL FRAIS DIVERS</td>
                                            <td class="amount-cell" style="padding-right: 10px;"><t t-esc="doc.total_expenses_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>

                        <!-- COÛT DE REVIENT FINAL -->
                        <div class="grand-summary">
                            <div class="row align-items-center">
                                <div class="col-8">
                                    <div style="font-size: 14px; font-weight: bold; text-transform: uppercase;">Coût de Revient Total</div>
                                </div>
                                <div class="col-4 text-right">
                                    <div style="font-size: 20px; font-weight: bold;"><t t-esc="doc.total_cost_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></div>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
