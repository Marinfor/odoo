<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_fiche_importation" model="ir.actions.report">
        <field name="name">Fiche Importation</field>
        <field name="model">import.tracking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">importation.report_fiche_importation_template</field>
        <field name="report_file">importation.report_fiche_importation_template</field>
        <field name="print_report_name">'Fiche Importation - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_import_tracking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_fiche_importation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11px; color: black; line-height: 1.2;">
                        <!-- Styles CSS -->
                        <style>
                            .main-box {
                                border: 1.5px solid black;
                                padding: 8px;
                                margin-bottom: 5px;
                                position: relative;
                            }
                            .section-header {
                                font-weight: bold;
                                text-transform: uppercase;
                                margin-bottom: 5px;
                                font-size: 12px;
                            }
                            .value-line {
                                display: inline-block;
                                border-bottom: 0.5px solid #000;
                                min-width: 150px;
                                text-align: center;
                                padding: 0 5px;
                            }
                            .label-text {
                                font-weight: bold;
                                font-size: 10px;
                                white-space: nowrap;
                            }
                            .total-footer {
                                text-align: right;
                                margin-top: 10px;
                                font-weight: bold;
                                border-top: 1px solid black;
                                padding-top: 4px;
                            }
                            .col-title {
                                font-size: 16px;
                                font-weight: bold;
                                text-align: center;
                                margin-bottom: 15px;
                            }
                            .row-spaced {
                                margin-bottom: 4px;
                            }
                            .border-bottom-only {
                                border-bottom: 1px solid black;
                                display: inline-block;
                                padding-bottom: 0px;
                            }
                        </style>

                        <!-- En-tête minimalist -->
                        <div class="row mb-2">
                            <div class="col-4">
                                <strong>N° DOSSIER :</strong> <span class="border-bottom-only" style="min-width: 80px;"><t t-esc="doc.folder_number"/></span>
                            </div>
                            <div class="col-4 text-center">
                                <!-- Place for Year or Code if any -->
                            </div>
                            <div class="col-4 text-right">
                                <t t-if="doc.contract_number"><strong>E14 :</strong> <t t-esc="doc.contract_number"/></t>
                            </div>
                        </div>

                        <div class="col-title" style="text-transform: uppercase; font-size: 22px; text-decoration: none;">FICHE IMPORTATION</div>

                        <!-- Section FOURNISSEURS -->
                        <div class="main-box">
                            <div class="row-spaced">
                                <span class="label-text">FOURNISSEURS :</span> <span class="value-line" style="min-width: 300px;"><t t-esc="doc.partner_id.name"/></span>
                            </div>
                            <div class="row-spaced" style="border-top: 1px solid black; padding-top: 5px; margin-top: 5px;">
                                <span class="label-text">ADRES :</span> <span class="value-line" style="min-width: 450px;">
                                    <t t-esc="doc.partner_id.street"/>, <t t-esc="doc.partner_id.city"/> <t t-esc="doc.partner_id.country_id.name"/>
                                </span>
                            </div>
                            <div class="row-spaced">
                                <div class="col-6 p-0">
                                    <span class="label-text">FACTURE FOURNISSEUR :</span> <span class="value-line" style="min-width: 150px;"><t t-esc="doc.invoice_number"/></span>
                                </div>
                                <div class="col-6 p-0 text-right">
                                    <span class="label-text">MONTANT :</span> 
                                    <span class="value-line" style="min-width: 30px;"><t t-esc="doc.initial_currency_id.symbol"/></span> 
                                    <span class="value-line" style="min-width: 120px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.initial_amount).replace(',', ' ').replace('.', ',')"/></span>
                                </div>
                            </div>
                            <div class="total-footer" style="border-top: 1px solid black;">
                                TOTAL : <span style="margin-right: 20px;"><t t-esc="doc.initial_currency_id.symbol"/></span> <t t-esc="'{0:,.2f}'.format(doc.initial_amount).replace(',', ' ').replace('.', ',')"/>
                            </div>
                        </div>

                        <!-- Section DOUANE ALGERIENNE -->
                        <div class="section-header" style="margin-top: 10px;">DOUANE ALGERIENNE</div>
                        <div class="main-box">
                            <div class="row mb-2">
                                <div class="col-6 p-0">
                                    <span class="label-text">N° D10 :</span> <span class="value-line" style="min-width: 250px;"><t t-esc="doc.d10_number"/></span>
                                </div>
                                <div class="col-6 p-0 text-right">
                                    <span class="label-text">DATE D 10 :</span> <span class="value-line" style="min-width: 150px;"><t t-esc="doc.date_d10" t-options='{"widget": "date"}'/></span>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-12 p-0">
                                    <span class="label-text">NATURE DU D10 :</span> <span class="value-line" style="min-width: 200px;"><t t-esc="doc.d10_nature or 'Revente en l\'état'"/></span>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-12 p-0">
                                    <span class="label-text">QUITTANCE N° :</span> <span class="value-line" style="min-width: 300px;"><t t-esc="doc.receipt_number"/></span>
                                </div>
                            </div>

                            <div class="row">
                                <!-- Colonne Gauche -->
                                <div class="col-6 pr-4">
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 100px; display: inline-block;">DROITS ET TAXES :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.amount_total_d10).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 100px; display: inline-block;">DROIT DOUANES :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.amount_dd).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 100px; display: inline-block;">TVA :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.amount_tva).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 100px; display: inline-block;">PRCT IBS :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.amount_prct).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 100px; display: inline-block;">TCS :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.amount_tcs).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                </div>
                                <!-- Colonne Droite -->
                                <div class="col-6 pl-4">
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 50px; display: inline-block;">DU :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.du_frais).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 50px; display: inline-block;">RPS :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.rps_frais).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 50px; display: inline-block;">AMD :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.amd_frais).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 50px; display: inline-block;">TEL :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.tel_frais).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-center" style="margin-top: 15px; font-weight: bold; border-top: 1px dotted black; padding-top: 5px;">
                                MONTANT QUITTANCE : <span class="value-line" style="min-width: 250px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.amount_total_d10).replace(',', ' ').replace('.', ',')"/> DZD</span>
                            </div>
                        </div>

                        <!-- Section TRANSIT -->
                        <div class="section-header" style="margin-top: 10px;">TRANSIT</div>
                        <div class="main-box">
                            <div class="row mb-2">
                                <div class="col-12 p-0">
                                    <span class="label-text">FACTURE DE TRANSIT N° :</span> <span class="value-line" style="min-width: 150px;"><t t-esc="doc.transit_invoice_number"/></span>
                                </div>
                            </div>
                            <div class="row mt-4">
                                <div class="col-6">
                                    <span class="label-text">FACTURE DE COMPTANT :</span> <span class="value-line" style="min-width: 150px;"></span>
                                </div>
                                <div class="col-6 text-right">
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 100px; display: inline-block;">MONTANT HT :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.transit_amount_ht).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced">
                                        <span class="label-text" style="width: 100px; display: inline-block;">TVA : <t t-esc="doc.transit_tva_rate"/> %</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(doc.transit_amount_tva).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                    <div class="row-spaced font-weight-bold">
                                        <span class="label-text" style="width: 100px; display: inline-block;">MONTANT TTC :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right; border-bottom: 2px solid black;"><t t-esc="'{0:,.2f}'.format(doc.transit_amount_ttc).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                </div>
                            </div>
                            <div class="total-footer">
                                TOTAL : <t t-esc="'{0:,.2f}'.format(doc.transit_amount_ttc).replace(',', ' ').replace('.', ',')"/> DZD
                            </div>
                        </div>

                        <!-- Section AUTRE -->
                        <div class="section-header" style="margin-top: 10px;">AUTRE :</div>
                        <div class="main-box">
                            <t t-foreach="doc.expense_line_ids" t-as="line">
                                <div class="row mb-1">
                                    <div class="col-7 p-0 overflow-hidden" style="white-space: nowrap;">
                                        <span class="label-text" style="min-width: 60px; display: inline-block;"><t t-esc="line.name[:25]"/> :</span> 
                                        <span class="value-line" style="min-width: 250px; border-bottom: 0.5px dotted black;"></span>
                                    </div>
                                    <div class="col-5 p-0 text-right">
                                        <span class="label-text">MONTANT :</span> 
                                        <span class="value-line" style="width: 150px; text-align: right;"><t t-esc="'{0:,.2f}'.format(line.total_amount).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                    </div>
                                </div>
                            </t>
                            
                            <!-- Frais de transport placeholder if any -->
                            <div class="row mt-2" style="border-top: 1px dashed #ccc; padding-top: 5px;">
                                <div class="col-12 text-right">
                                    <span class="label-text">TOTAL :</span> 
                                    <span class="value-line" style="min-width: 150px; text-align: right; border-bottom: 2px solid black;"><t t-esc="'{0:,.2f}'.format(doc.total_expenses_ttc).replace(',', ' ').replace('.', ',')"/> DZD</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
