<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_fiche_importation" model="ir.actions.report">
        <field name="name">Fiche Importation</field>
        <field name="model">import.tracking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">importation.report_fiche_importation_template</field>
        <field name="report_file">importation.report_fiche_importation_template</field>
        <field name="print_report_name">'Fiche Importation - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_import_tracking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_fiche_importation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="article" t-att-data-oe-model="doc._name" t-att-data-oe-id="doc.id" style="font-family: Arial, sans-serif; font-size: 11px; color: #000; width: 100%; margin: 0; padding: 0;">
                    
                    <!-- Inline CSS for Maximum Resilience -->
                    <style type="text/css">
                        @page {
                            margin: 1cm;
                            size: A4;
                        }
                        .page-container {
                            width: 100%;
                            padding: 0;
                            margin: 0;
                        }
                        .header-table {
                            width: 100%;
                            border-bottom: 2px solid #000;
                            margin-bottom: 20px;
                        }
                        .title-box {
                            width: 100%;
                            text-align: center;
                            font-size: 22pt;
                            font-weight: bold;
                            border: 2px solid #000;
                            padding: 10px;
                            margin-bottom: 30px;
                        }
                        .section-container {
                            border: 1.5px solid #000;
                            margin-bottom: 25px;
                        }
                        .section-label {
                            background-color: #E6E6E6;
                            padding: 5px 10px;
                            font-weight: bold;
                            border-bottom: 1.5px solid #000;
                            text-transform: uppercase;
                            font-size: 10pt;
                        }
                        .content-table {
                            width: 100%;
                            border-collapse: collapse;
                        }
                        .data-row td {
                            padding: 8px 10px;
                            border-bottom: 1px solid #EEE;
                        }
                        .label-bold {
                            font-weight: bold;
                            text-transform: uppercase;
                            font-size: 9pt;
                            width: 150px;
                        }
                        .value-field {
                            border-bottom: 0.5px solid #DDD;
                        }
                        .total-section {
                            background-color: #F2F2F2;
                            font-weight: bold;
                            border-top: 1.5px solid #000;
                            padding: 10px;
                            text-align: right;
                        }
                        .text-right { text-align: right; }
                        .text-bold { font-weight: bold; }
                    </style>

                    <div class="page-container">
                        <!-- Identifiants Haut -->
                        <table class="header-table">
                            <tr>
                                <td style="width: 50%; font-size: 14pt; font-weight: bold; padding-bottom: 10px;">
                                    REF : <t t-esc="doc.name"/>
                                </td>
                                <td style="width: 50%; text-align: right; font-size: 14pt; font-weight: bold; padding-bottom: 10px;">
                                    <t t-if="doc.contract_number">CONTRAT : <t t-esc="doc.contract_number"/></t>
                                </td>
                            </tr>
                        </table>

                        <div class="title-box">FICHE D'IMPORTATION</div>

                        <!-- SECTION FOURNISSEUR -->
                        <div class="section-container">
                            <div class="section-label">Informations Fournisseur</div>
                            <table class="content-table" style="padding: 10px;">
                                <tr>
                                    <td style="width: 60%; vertical-align: top; padding: 15px;">
                                        <div style="margin-bottom: 15px;">
                                            <span class="label-bold">Fournisseur :</span><br/>
                                            <span style="font-size: 14pt; font-weight: bold;"><t t-esc="doc.partner_id.name"/></span>
                                        </div>
                                        <div>
                                            <span class="label-bold">Adresse :</span><br/>
                                            <t t-esc="doc.partner_id.street"/>, <t t-esc="doc.partner_id.city"/> <t t-esc="doc.partner_id.country_id.name"/>
                                        </div>
                                    </td>
                                    <td style="width: 40%; vertical-align: top; padding: 15px; border-left: 1px dashed #000;">
                                        <table style="width: 100%;">
                                            <tr><td class="label-bold">Facture N° :</td><td class="text-right"><t t-esc="doc.invoice_number"/></td></tr>
                                            <tr><td class="label-bold">Date :</td><td class="text-right"><t t-esc="doc.invoice_date"/></td></tr>
                                            <tr><td colspan="2" style="padding-top: 10px; border-bottom: 1px solid #000;"></td></tr>
                                            <tr><td class="label-bold" style="padding-top: 5px;">Montant Devise :</td><td class="text-right text-bold" style="padding-top: 5px;"><t t-esc="doc.initial_amount" t-options='{"widget": "monetary", "display_currency": doc.initial_currency_id}'/></td></tr>
                                            <tr><td class="label-bold">Taux Change :</td><td class="text-right"><t t-esc="doc.exchange_rate"/></td></tr>
                                            <tr style="font-size: 14pt; background-color: #EEE;"><td class="label-bold" style="padding: 5px;">Total (DZD) :</td><td class="text-right text-bold" style="padding: 5px;"><t t-esc="doc.amount_dzd_working" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- SECTION DOUANE -->
                        <div class="section-container">
                            <div class="section-label">Douane Algérienne</div>
                            <div style="padding: 15px;">
                                <table style="width: 100%; border-bottom: 1px solid #000; padding-bottom: 10px; margin-bottom: 15px;">
                                    <tr>
                                        <td><span class="label-bold">N° D10 :</span> <t t-esc="doc.d10_number"/></td>
                                        <td class="text-center"><span class="label-bold">Date :</span> <t t-esc="doc.date_d10"/></td>
                                        <td class="text-right"><span class="label-bold">Quittance N° :</span> <span class="text-bold" style="font-size: 13pt;"><t t-esc="doc.receipt_number"/></span></td>
                                    </tr>
                                </table>
                                <table style="width: 100%;">
                                    <tr>
                                        <td style="width: 48%; vertical-align: top;">
                                            <div style="font-size: 8pt; font-weight: bold; border-bottom: 1px solid #000;">TAXES SUR PRODUITS</div>
                                            <table style="width: 100%;">
                                                <tr class="data-row"><td>DD</td><td class="text-right text-bold"><t t-esc="doc.amount_dd" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr class="data-row"><td>TVA</td><td class="text-right text-bold"><t t-esc="doc.amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr class="data-row"><td>PRCT / IBS</td><td class="text-right text-bold"><t t-esc="doc.amount_prct" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr class="data-row"><td>TCS</td><td class="text-right text-bold"><t t-esc="doc.amount_tcs" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            </table>
                                        </td>
                                        <td style="width: 4%;"></td>
                                        <td style="width: 48%; vertical-align: top;">
                                            <div style="font-size: 8pt; font-weight: bold; border-bottom: 1px solid #000;">FRAIS FIXES &amp; QUITTANCE</div>
                                            <table style="width: 100%;">
                                                <tr class="data-row"><td>RPS</td><td class="text-right text-bold"><t t-esc="doc.rps_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr class="data-row"><td>AMD</td><td class="text-right text-bold"><t t-esc="doc.amd_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr class="data-row"><td>TEL</td><td class="text-right text-bold"><t t-esc="doc.tel_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr class="data-row"><td>DU</td><td class="text-right text-bold"><t t-esc="doc.du_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            </table>
                                        </td>
                                    </tr>
                                </table>
                                <div class="total-section" style="margin-top: 20px;">
                                    <span style="font-size: 13pt;">MONTANT QUITTANCE TOTAL :</span>
                                    <span style="font-size: 20pt; margin-left: 20px;"><t t-esc="doc.amount_total_d10" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></span>
                                </div>
                            </div>
                        </div>

                        <!-- SECTION TRANSIT -->
                        <div class="section-container">
                            <div class="section-label">Transit &amp; Logistique</div>
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="width: 50%; padding: 15px; vertical-align: top;">
                                        <span class="label-bold">Transitaire :</span><br/>
                                        <span class="text-bold"><t t-esc="doc.forwarder_id.name"/></span><br/><br/>
                                        <span class="label-bold">Facture Transit N° :</span><br/>
                                        <t t-esc="doc.transit_invoice_number"/>
                                    </td>
                                    <td style="width: 50%; border-left: 1px solid #000; padding: 0;">
                                        <table style="width: 100%;">
                                            <tr class="data-row"><td style="padding-left: 15px;">MONTANT HT</td><td class="text-right text-bold" style="padding-right: 15px;"><t t-esc="doc.transit_amount_ht" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr class="data-row"><td style="padding-left: 15px;">TVA (<t t-esc="doc.transit_tva_rate"/>%)</td><td class="text-right text-bold" style="padding-right: 15px;"><t t-esc="doc.transit_amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr style="background-color: #EEE; font-weight: bold;"><td style="padding: 10px 15px;">TOTAL TTC</td><td class="text-right" style="padding: 10px 15px;"><t t-esc="doc.transit_amount_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- COÛT DE REVIENT FINAL -->
                        <table style="width: 100%; border: 3px solid #000; margin-top: 10px;">
                            <tr style="background-color: #000; color: #FFF;">
                                <td style="padding: 20px; font-size: 16pt; font-weight: bold; text-transform: uppercase;">
                                    Coût de Revient Total de l'Importation
                                </td>
                                <td style="padding: 20px; text-align: right; font-size: 30pt; font-weight: bold;">
                                    <t t-esc="doc.total_cost_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
