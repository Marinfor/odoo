<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_fiche_importation" model="ir.actions.report">
        <field name="name">Fiche Importation</field>
        <field name="model">import.tracking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">importation.report_fiche_importation_template</field>
        <field name="report_file">importation.report_fiche_importation_template</field>
        <field name="print_report_name">'Fiche Importation - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_import_tracking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_fiche_importation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <!-- Hide Header and Footer of Company via CSS -->
                    <style type="text/css">
                        .header, .footer {
                            display: none !important;
                        }
                        .page {
                            font-family: Arial, sans-serif;
                            font-size: 11px;
                            color: #000;
                            margin-top: -50px; /* Offset for hidden header */
                        }
                        table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
                        .b-box { border: 1.5px solid black; }
                        .b-head { background-color: #eee; border-bottom: 1.5px solid black; padding: 5px; font-weight: bold; text-transform: uppercase; }
                        .b-content { padding: 10px; }
                        .text-right { text-align: right; }
                        .text-bold { font-weight: bold; }
                    </style>

                    <div class="page">
                        <!-- References Header -->
                        <table style="border-bottom: 2px solid black; margin-bottom: 20px;">
                            <tr>
                                <td style="font-size: 14pt; font-weight: bold;">REF : <t t-esc="doc.name"/></td>
                                <td style="text-align: right; font-size: 14pt; font-weight: bold;">
                                    <t t-if="doc.contract_number">CONTRAT : <t t-esc="doc.contract_number"/></t>
                                </td>
                            </tr>
                        </table>

                        <div style="text-align: center; font-size: 22pt; font-weight: bold; border: 2px solid black; padding: 10px; margin-bottom: 20px;">
                            FICHE D'IMPORTATION
                        </div>

                        <!-- BLOC FOURNISSEUR -->
                        <div class="b-box">
                            <div class="b-head">Informations Fournisseur</div>
                            <div class="b-content">
                                <table style="width: 100%;">
                                    <tr>
                                        <td style="width: 60%; vertical-align: top;">
                                            <span style="font-weight: bold; text-transform: uppercase; font-size: 9pt;">Fournisseur :</span><br/>
                                            <span style="font-size: 14pt; font-weight: bold;"><t t-esc="doc.partner_id.name"/></span><br/><br/>
                                            <span style="font-weight: bold; text-transform: uppercase; font-size: 9pt;">Adresse :</span><br/>
                                            <t t-esc="doc.partner_id.street"/>, <t t-esc="doc.partner_id.city"/> <t t-esc="doc.partner_id.country_id.name"/>
                                        </td>
                                        <td style="width: 40%; vertical-align: top;">
                                            <table style="width: 100%;">
                                                <tr><td><strong>Facture N° :</strong></td><td class="text-right"><t t-esc="doc.invoice_number"/></td></tr>
                                                <tr><td><strong>Date :</strong></td><td class="text-right"><t t-esc="doc.invoice_date"/></td></tr>
                                                <tr><td colspan="2" style="border-bottom: 1px solid #000; padding-top: 5px;"></td></tr>
                                                <tr><td style="padding-top: 5px;"><strong>Montant Devise :</strong></td><td class="text-right text-bold" style="padding-top: 5px;"><t t-esc="doc.initial_amount" t-options='{"widget": "monetary", "display_currency": doc.initial_currency_id}'/></td></tr>
                                                <tr><td><strong>Taux Change :</strong></td><td class="text-right"><t t-esc="doc.exchange_rate"/></td></tr>
                                                <tr style="background-color: #eee; font-weight: bold;"><td>TOTAL (DZD) :</td><td class="text-right"><t t-esc="doc.amount_dzd_working" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            </table>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- BLOC DOUANE -->
                        <div class="b-box">
                            <div class="b-head">Douane Algérienne</div>
                            <div class="b-content">
                                <table style="width: 100%; border-bottom: 1px solid black; margin-bottom: 10px;">
                                    <tr>
                                        <td><strong>N° D10 :</strong> <t t-esc="doc.d10_number"/></td>
                                        <td class="text-center"><strong>DATE :</strong> <t t-esc="doc.date_d10"/></td>
                                        <td class="text-right"><strong>QUITTANCE N° :</strong> <span class="text-bold" style="font-size: 13pt;"><t t-esc="doc.receipt_number"/></span></td>
                                    </tr>
                                </table>
                                <table style="width: 100%;">
                                    <tr>
                                        <td style="width: 48%; vertical-align: top;">
                                            <div style="font-size: 8pt; font-weight: bold; border-bottom: 1px solid black;">Taxes Produits</div>
                                            <table style="width: 100%;">
                                                <tr style="border-bottom: 1px solid #eee;"><td>DD</td><td class="text-right text-bold"><t t-esc="doc.amount_dd" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>TVA</td><td class="text-right text-bold"><t t-esc="doc.amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>PRCT / IBS</td><td class="text-right text-bold"><t t-esc="doc.amount_prct" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>TCS</td><td class="text-right text-bold"><t t-esc="doc.amount_tcs" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            </table>
                                        </td>
                                        <td style="width: 4%;"></td>
                                        <td style="width: 48%; vertical-align: top;">
                                            <div style="font-size: 8pt; font-weight: bold; border-bottom: 1px solid black;">Frais Fixes</div>
                                            <table style="width: 100%;">
                                                <tr style="border-bottom: 1px solid #eee;"><td>RPS</td><td class="text-right text-bold"><t t-esc="doc.rps_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>AMD</td><td class="text-right text-bold"><t t-esc="doc.amd_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>TEL</td><td class="text-right text-bold"><t t-esc="doc.tel_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                                <tr style="border-bottom: 1px solid #eee;"><td>DU</td><td class="text-right text-bold"><t t-esc="doc.du_frais" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            </table>
                                        </td>
                                    </tr>
                                </table>
                                <div style="margin-top: 15px; text-align: right; border-top: 2px solid black; padding-top: 5px; font-weight: bold;">
                                    <span style="font-size: 13pt;">MONTANT QUITTANCE TOTAL :</span>
                                    <span style="font-size: 20pt; margin-left: 10px;"><t t-esc="doc.amount_total_d10" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></span>
                                </div>
                            </div>
                        </div>

                        <!-- BLOC TRANSIT -->
                        <div class="b-box">
                            <div class="b-head">Transit &amp; Logistique</div>
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="width: 50%; padding: 10px; vertical-align: top;">
                                        <strong>Transitaire :</strong> <t t-esc="doc.forwarder_id.name"/><br/>
                                        <strong>Facture Transit N° :</strong> <t t-esc="doc.transit_invoice_number"/>
                                    </td>
                                    <td style="width: 50%; border-left: 1px solid #000;">
                                        <table style="width: 100%;">
                                            <tr style="border-bottom: 1px solid #eee;"><td style="padding: 5px;">HT</td><td class="text-right text-bold" style="padding: 5px;"><t t-esc="doc.transit_amount_ht" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr style="border-bottom: 1px solid #eee;"><td style="padding: 5px;">TVA (<t t-esc="doc.transit_tva_rate"/>%)</td><td class="text-right text-bold" style="padding: 5px;"><t t-esc="doc.transit_amount_tva" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                            <tr style="background-color: #eee; font-weight: bold;"><td style="padding: 8px;">Total Transit TTC</td><td class="text-right" style="padding: 8px;"><t t-esc="doc.transit_amount_ttc" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td></tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- TOTAL REVIENT -->
                        <table style="width: 100%; border: 3px solid black; margin-top: 10px; background-color: #000; color: #fff;">
                            <tr>
                                <td style="padding: 15px; font-size: 16pt; font-weight: bold; text-transform: uppercase;">Coût de Revient Total</td>
                                <td style="padding: 15px; text-align: right; font-size: 30pt; font-weight: bold;"><t t-esc="doc.total_cost_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
